# API
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000

# Retrieval
RAG_RETRIEVAL_MODE=lexical
RAG_EMBEDDINGS_ENABLED=false
# Built-in deterministic embeddings: hashing-underwriting-v1
# Nebius Token Factory embeddings:  nebius:BAAI/bge-en-icl  (needs NEBIUS_API_KEY)
# Local sentence-transformers:      sentence-transformers:all-MiniLM-L6-v2
EMBEDDING_MODEL=hashing-underwriting-v1

# Chunking strategy for ingestion: header (semantic, default) or fixed (size-based)
RAG_CHUNK_STRATEGY=header

# Structured LLM output
# Keep disabled for deterministic local runs. Put a real key in .env, never here.
LLM_STRUCTURED_OUTPUT_ENABLED=false
# Provider: openai | nebius | disabled
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_PROMPT_VERSION=structured-llm-v1
OPENAI_API_KEY=

# Nebius Token Factory (OpenAI-compatible). Used when LLM_PROVIDER=nebius or
# EMBEDDING_MODEL=nebius:<model>. Either NEBIUS_API_KEY or OPENAI_API_KEY works.
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/

# Observability
# memory records spans in-process for tests and audit inspection.
# logging also emits completed spans to application logs.
# otel exports through the OpenTelemetry API when configured by the host app.
TRACE_BACKEND=memory

# Storage
DATABASE_URL=sqlite:///storage/underwriting.db

# Modal deployment
MODAL_APP_NAME=agentic-underwriter
MODAL_DATA_VOLUME=agentic-underwriter-data

# LangSmith (optional — off by default; set LANGSMITH_TRACING=true to enable)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=AgenticUnderwriter
